# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# package-lock.json NO se commitea a propósito: el lock generado en Windows
# resuelve un arbol distinto al de macOS/Linux y rompe `npm ci` en EAS
# (Missing @react-native/metro-config, @testing-library/dom, etc.).
# Sin lock, EAS usa `npm install` y resuelve en su propia maquina. Ver eas builds 76ad62a4 / c7062ab5.
package-lock.json

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# EAS submit credentials (NUNCA commitear). El README sí se trackea.
credentials/*
!credentials/README.md

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

